# ============================================================
# Pi dotfiles — Environment Variables Template
# ============================================================
# Copy this to ~/.dotfiles.env (NOT tracked by git) and fill in your keys.
# The .bashrc will source this file automatically.

# --- LLM API Keys ---
export DEEPSEEK_API_KEY="sk-your-deepseek-key"
export SILICONFLOW_API_KEY="sk-your-siliconflow-key"
export OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"
export OPENCODE_ZEN_API_KEY="sk-your-opencode-zen-key"
export NVIDIA_API_KEY="nvapi-your-nvidia-key"

# --- Search / Tools ---
export TAVILY_API_KEY="tvly-dev-your-tavily-key"

# --- WebDAV Sync (坚果云) ---
export PI_WEBDAV_PASSWORD="your-webdav-password"

# --- Obsidian LLM-Wiki ---
export OBSIDIAN_LLM_WIKI_KEY="your-obsidian-wiki-key"
export OBSIDIAN_LLM_WIKI_SMART_KEY="your-obsidian-api-key"
