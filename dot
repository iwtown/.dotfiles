#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# dot — Pi dotfiles management CLI
# ============================================================
# Usage: dot [init|update|stow|doctor|link|unlink]

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly RESET='\033[0m'
readonly BOLD='\033[1m'

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly DOTFILES_DIR
readonly HOME_DIR="${DOTFILES_DIR}/home"
readonly PACKAGES_DIR="${DOTFILES_DIR}/packages"
readonly VERSION="1.0.0"

# ===== Helpers =====
print_header() { echo -e "\n${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"; }
print_success() { echo -e "${GREEN}✓${RESET} $1"; }
print_error() { echo -e "${RED}✗${RESET} $1" >&2; }
print_warning() { echo -e "${YELLOW}⚠${RESET} $1"; }
print_info() { echo -e "${CYAN}ℹ${RESET} $1"; }
command_exists() { command -v "$1" >/dev/null 2>&1; }

# ===== Commands =====

cmd_stow() {
    print_header "Stowing dotfiles"
    
    if ! command_exists stow; then
        print_error "GNU Stow is not installed. Run: sudo apt install stow"
        return 1
    fi
    
    cd "${DOTFILES_DIR}"
    
    # Stow each top-level directory in home/ to ~
    # Use --no-folding to avoid directory conflicts
    stow --dir="${HOME_DIR}" --target="${HOME}" --restow --no-folding .
    
    print_success "Dotfiles stowed to ${HOME}"
}

cmd_init() {
    print_header "Pi dotfiles — Initial Setup v${VERSION}"
    echo ""
    
    # 1. Install apt packages
    print_info "Step 1: Installing apt packages..."
    if [ -f "${PACKAGES_DIR}/apt-bundle" ]; then
        sudo apt update -qq
        xargs -a "${PACKAGES_DIR}/apt-bundle" sudo apt install -y < /dev/null
        print_success "apt packages installed"
    else
        print_warning "No apt-bundle found, skipping"
    fi
    
    # 2. Check for ~/.dotfiles.env
    print_info "Step 2: Checking environment..."
    if [ ! -f "${HOME}/.dotfiles.env" ]; then
        print_warning "~/.dotfiles.env not found!"
        print_info "Creating from template..."
        cp "${DOTFILES_DIR}/.env.example" "${HOME}/.dotfiles.env"
        print_warning "Edit ~/.dotfiles.env with your API keys before using Pi!"
    else
        print_success "~/.dotfiles.env exists"
    fi
    
    # 3. Copy sensitive config templates if not present
    print_info "Step 3: Setting up Pi config..."
    setup_pi_config
    
    # 4. Stow
    print_info "Step 4: Stowing dotfiles..."
    cmd_stow
    
    # 5. Source env for this session
    if [ -f "${HOME}/.dotfiles.env" ]; then
        set +u
        . "${HOME}/.dotfiles.env"
        set -u
    fi
    
    # 6. Install pi if needed
    print_info "Step 5: Checking Pi Agent..."
    if ! command_exists pi; then
        print_info "Installing pi..."
        npm install -g @earendil-works/pi-coding-agent
    fi
    print_success "Pi Agent: $(pi --version 2>/dev/null || echo 'installed')"
    
    # 7. Install pi packages
    print_info "Step 6: Installing Pi packages..."
    if command_exists pi; then
        pi install --all 2>&1 | tail -5 || print_warning "Some pi packages may need manual install"
    fi
    
    # 8. Link pi-llm-wiki submodule
    print_info "Step 7: Linking pi-llm-wiki..."
    local submodule_path="${DOTFILES_DIR}/modules/pi-llm-wiki"
    if [ -d "${submodule_path}/src" ]; then
        if [ ! -e "${HOME}/pi-llm-wiki" ]; then
            ln -sf "${submodule_path}" "${HOME}/pi-llm-wiki"
            print_success "pi-llm-wiki linked: ~/pi-llm-wiki -> modules/pi-llm-wiki"
        elif [ -L "${HOME}/pi-llm-wiki" ]; then
            print_success "pi-llm-wiki already linked"
        else
            print_warning "~/pi-llm-wiki exists but is not a symlink to submodule"
        fi
    else
        print_warning "pi-llm-wiki submodule not found!"
        print_info "Run: git submodule update --init --recursive"
    fi
    
    echo ""
    print_success "Setup complete!"
    print_info "Restart your shell or run: source ~/.bashrc"
    print_info "Run 'dot doctor' to verify your installation"
}

setup_pi_config() {
    # Copy .example files to actual config if they don't exist
    local pi_agent="${HOME}/.pi/agent"
    mkdir -p "${pi_agent}" "${HOME}/.pi"
    
    local examples=(
        "${DOTFILES_DIR}/home/.pi/agent/auth.json.example:${pi_agent}/auth.json"
        "${DOTFILES_DIR}/home/.pi/agent/settings.webdav.json.example:${pi_agent}/settings.webdav.json"
        "${DOTFILES_DIR}/home/.pi/web-search.json.example:${HOME}/.pi/web-search.json"
        "${DOTFILES_DIR}/home/.pi/web-search-cn.json.example:${HOME}/.pi/web-search-cn.json"
    )
    
    for pair in "${examples[@]}"; do
        local src="${pair%%:*}"
        local dst="${pair#*:}"
        if [ ! -f "${dst}" ]; then
            cp "${src}" "${dst}"
            print_info "Created ${dst} (edit with your keys)"
        fi
    done
}

cmd_update() {
    print_header "Updating dotfiles"
    
    cd "${DOTFILES_DIR}"
    
    # Pull latest
    print_info "Pulling latest changes..."
    git pull --rebase
    git submodule update --init --recursive
    
    # Update pi-llm-wiki if linked
    if [ -L "${HOME}/pi-llm-wiki" ] && [ -d "${HOME}/pi-llm-wiki/.git" ]; then
        print_info "Updating pi-llm-wiki..."
        git -C "${HOME}/pi-llm-wiki" pull --rebase 2>&1 || print_warning "pi-llm-wiki pull failed (uncommitted changes?)"
    fi
    
    # Update apt packages
    print_info "Updating apt packages..."
    sudo apt update -qq && sudo apt upgrade -y
    
    # Re-stow
    print_info "Re-stowing..."
    cmd_stow
    
    # Update pi
    if command_exists pi; then
        print_info "Updating pi..."
        npm update -g @earendil-works/pi-coding-agent
        pi update 2>&1 | tail -3 || true
    fi
    
    print_success "Update complete!"
}

cmd_doctor() {
    print_header "Dotfiles Health Check"
    
    local issues=0
    
    check() {
        local desc="$1"
        shift
        if "$@"; then
            print_success "${desc}"
        else
            print_error "${desc}"
            ((issues++))
        fi
    }
    
    echo ""
    echo -e "${BOLD}Core Tools${RESET}"
    check "GNU Stow" command_exists stow
    check "Git" command_exists git
    check "tmux" command_exists tmux
    check "curl" command_exists curl
    
    echo ""
    echo -e "${BOLD}Dev Tools${RESET}"
    check "ripgrep" command_exists rg
    check "fd" command_exists fdfind || command_exists fd
    check "fzf" command_exists fzf
    check "zoxide" command_exists zoxide
    check "bat" command_exists batcat || command_exists bat
    check "eza" command_exists eza
    check "jq" command_exists jq
    check "yq" command_exists yq
    check "delta" command_exists delta
    
    echo ""
    echo -e "${BOLD}Pi Agent${RESET}"
    check "pi CLI" command_exists pi
    if command_exists pi; then
        check "pi version" pi --version 2>/dev/null
    fi
    
    echo ""
    echo -e "${BOLD}Configuration${RESET}"
    check "~/.dotfiles.env" test -f "${HOME}/.dotfiles.env"
    check "~/.bashrc symlinked" test -L "${HOME}/.bashrc" -o -f "${HOME}/.bashrc"
    check "~/.gitconfig exists" test -f "${HOME}/.gitconfig"
    check "~/.tmux.conf exists" test -f "${HOME}/.tmux.conf"
    check "~/.pi/agent/settings.json" test -f "${HOME}/.pi/agent/settings.json"
    check "~/.pi/agent/models.json" test -f "${HOME}/.pi/agent/models.json"
    check "pi-llm-wiki exists" test -d "${HOME}/pi-llm-wiki/src"
    
    echo ""
    echo -e "${BOLD}Sensitive Files (should exist)${RESET}"
    check "~/.pi/agent/auth.json" test -f "${HOME}/.pi/agent/auth.json"
    check "~/.pi/web-search.json" test -f "${HOME}/.pi/web-search.json"
    check "~/.pi/web-search-cn.json" test -f "${HOME}/.pi/web-search-cn.json"
    
    echo ""
    echo -e "${BOLD}Symlink Check${RESET}"
    local broken=0
    while IFS= read -r link; do
        if [ -L "${link}" ] && [ ! -e "${link}" ]; then
            print_warning "Broken symlink: ${link}"
            ((broken++))
        fi
    done < <(find "${HOME}" -maxdepth 3 -type l 2>/dev/null || true)
    if [ "${broken}" -eq 0 ]; then
        print_success "No broken symlinks"
    fi
    
    echo ""
    if [ "${issues}" -eq 0 ]; then
        print_success "All checks passed!"
    else
        print_warning "${issues} issue(s) found. Run 'dot init' to fix."
    fi
}

cmd_link() {
    print_header "Linking dot globally"
    local target="${HOME}/.local/bin/dot"
    mkdir -p "${HOME}/.local/bin"
    ln -sf "${DOTFILES_DIR}/dot" "${target}"
    print_success "Linked: ${target} -> ${DOTFILES_DIR}/dot"
    print_info "Make sure ~/.local/bin is in your PATH"
}

cmd_unlink() {
    print_header "Unlinking dot"
    rm -f "${HOME}/.local/bin/dot"
    print_success "Removed ~/.local/bin/dot"
}

cmd_secrets() {
    print_header "Secrets Setup"
    
    if [ ! -f "${HOME}/.dotfiles.env" ]; then
        cp "${DOTFILES_DIR}/.env.example" "${HOME}/.dotfiles.env"
        print_info "Created ~/.dotfiles.env from template"
        print_warning "EDIT THIS FILE with your actual API keys!"
        print_info "  vim ~/.dotfiles.env"
    else
        print_info "~/.dotfiles.env already exists"
    fi
    
    setup_pi_config
}

cmd_status() {
    print_header "Dotfiles Status"
    
    cd "${DOTFILES_DIR}"
    
    # Git status
    echo -e "${BOLD}Git Changes:${RESET}"
    if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
        print_success "No uncommitted changes"
    else
        git -c color.status=always status --short
    fi
    
    echo ""
    echo -e "${BOLD}Extension Drift:${RESET}"
    local ext_dir="${HOME}/.pi/agent/extensions"
    local dotfiles_ext="${DOTFILES_DIR}/home/.pi/agent/extensions"
    local drift=0
    
    # Find files in live extensions that aren't in dotfiles (and aren't npm-managed)
    while IFS= read -r -d '' file; do
        local rel="${file#${ext_dir}/}"
        # Skip npm-managed stuff
        case "${rel}" in
            node_modules|node_modules/*|package.json|package-lock.json|planning-with-files) continue ;;
        esac
        
        if [ ! -e "${dotfiles_ext}/${rel}" ]; then
            if [ -L "${file}" ]; then
                print_info "Symlink only in live: ${rel}"
            else
                print_warning "Not in dotfiles: ${rel} (run 'dot sync' to add)"
                ((drift++))
            fi
        fi
    done < <(find "${ext_dir}" -mindepth 1 -maxdepth 3 \( -type f -o -type d \) -print0 2>/dev/null || true)
    
    # Find symlinks in dotfiles that are broken in live
    while IFS= read -r -d '' file; do
        local rel="${file#${dotfiles_ext}/}"
        if [ -L "${ext_dir}/${rel}" ] && [ ! -e "${ext_dir}/${rel}" ]; then
            print_warning "Broken symlink: extensions/${rel}"
            ((drift++))
        fi
    done < <(find "${dotfiles_ext}" -type f -print0 2>/dev/null || true)
    
    if [ "${drift}" -eq 0 ]; then
        print_success "Extensions in sync"
    fi
    
    echo ""
    echo -e "${BOLD}Settings:${RESET}"
    if [ -L "${HOME}/.pi/agent/settings.json" ]; then
        print_success "settings.json is symlinked (auto-sync)"
    else
        print_warning "settings.json is NOT a symlink — changes won't sync to dotfiles"
    fi
}

cmd_sync() {
    print_header "Syncing extensions to dotfiles"
    
    local ext_dir="${HOME}/.pi/agent/extensions"
    local dotfiles_ext="${DOTFILES_DIR}/home/.pi/agent/extensions"
    local count=0
    
    mkdir -p "${dotfiles_ext}"
    
    while IFS= read -r -d '' file; do
        local rel="${file#${ext_dir}/}"
        local dirpart="${rel%/*}"
        
        # Skip npm-managed stuff
        case "${rel}" in
            node_modules|node_modules/*|package.json|package-lock.json|planning-with-files) continue ;;
        esac
        
        # Skip if already in dotfiles
        if [ -e "${dotfiles_ext}/${rel}" ]; then continue; fi
        
        # Skip symlinks (probably from npm packages pointing into node_modules)
        if [ -L "${file}" ]; then continue; fi
        
        print_info "Adding: extensions/${rel}"
        
        if [ -d "${file}" ]; then
            mkdir -p "${dotfiles_ext}/${rel}"
            cp -r "${file}/"* "${dotfiles_ext}/${rel}/" 2>/dev/null || true
        else
            mkdir -p "${dotfiles_ext}/${dirpart}"
            cp "${file}" "${dotfiles_ext}/${rel}"
        fi
        
        # Remove original and create symlink back to dotfiles
        rm -rf "${file}"
        if [ -d "${dotfiles_ext}/${rel}" ]; then
            # For directories: symlink individual files (stow pattern)
            while IFS= read -r -d '' f; do
                local frel="${f#${dotfiles_ext}/${rel}/}"
                mkdir -p "$(dirname "${ext_dir}/${rel}/${frel}")"
                ln -sf "${f}" "${ext_dir}/${rel}/${frel}"
            done < <(find "${dotfiles_ext}/${rel}" -type f -print0)
        else
            ln -sf "${dotfiles_ext}/${rel}" "${ext_dir}/${rel}"
        fi
        
        ((count++))
        print_success "Synced: extensions/${rel}"
    done < <(find "${ext_dir}" -mindepth 1 -maxdepth 3 \( -type f -o -type d \) -print0 2>/dev/null || true)
    
    if [ "${count}" -eq 0 ]; then
        print_info "No new extensions to sync"
    else
        print_success "Synced ${count} item(s). Review with 'dot status' then commit."
    fi
    
    # Also sync pi-llm-wiki if present
    if [ -d "${HOME}/pi-llm-wiki" ] && [ -d "${HOME}/pi-llm-wiki/.git" ]; then
        echo ""
        print_info "pi-llm-wiki status:"
        git -C "${HOME}/pi-llm-wiki" status --short | head -5 || true
    fi
}

cmd_help() {
    cat << EOF

${BOLD}dot v${VERSION}${RESET} — Pi dotfiles management CLI

${BOLD}Commands:${RESET}
  ${GREEN}init${RESET}        Full setup: apt + stow + pi + packages
  ${GREEN}update${RESET}      Pull latest + apt upgrade + re-stow + pi update
  ${GREEN}stow${RESET}        Re-symlink dotfiles from home/ to ~
  ${GREEN}status${RESET}      Show dotfile changes + extension drift
  ${GREEN}sync${RESET}        Move new extensions into dotfiles
  ${GREEN}doctor${RESET}      Health check: tools, config, symlinks
  ${GREEN}secrets${RESET}     Setup .env and sensitive config from templates
  ${GREEN}link${RESET}        Install dot globally (~/.local/bin/dot)
  ${GREEN}unlink${RESET}      Remove global dot symlink

${BOLD}Daily Workflow:${RESET}
  dot status      # Check what changed
  dot sync        # Move new extensions to dotfiles
  git commit -m "..."  # Save your config

${BOLD}Quick Start:${RESET}
  ./dot init       # First-time setup
  ./dot doctor     # Verify everything works

${BOLD}Repo:${RESET} https://github.com/wtown/dotfiles
EOF
}

# ===== Main =====
case "${1:-help}" in
    init)       cmd_init ;;
    update)     cmd_update ;;
    stow)       cmd_stow ;;
    doctor)     cmd_doctor ;;
    link)       cmd_link ;;
    unlink)     cmd_unlink ;;
    secrets)    cmd_secrets ;;
    status)     cmd_status ;;
    sync)       cmd_sync ;;
    help|--help|-h) cmd_help ;;
    *)
        print_error "Unknown command: ${1:-}"
        cmd_help
        exit 1
        ;;
esac
