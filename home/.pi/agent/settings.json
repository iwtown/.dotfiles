{
  "lastChangelogVersion": "0.79.9",
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 60000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "shellPath": "/bin/bash",
  "defaultProvider": "sensenova",
  "defaultModel": "deepseek-v4-flash",
  "quietStartup": true,
  "enabledModels": [
    "deepseek/deepseek-v4-flash",
    "sensenova/deepseek-v4-flash",
    "opencode-zen/deepseek-v4-flash-free",
    "deepseek/deepseek-v4-pro",
    "siliconflow/stepfun-ai/Step-3.5-Flash",
    "siliconflow/Qwen/Qwen3.5-397B-A17B",
    "siliconflow/Qwen/Qwen3.6-35B-A3B",
    "siliconflow/Qwen/Qwen3.5-35B-A3B",
    "siliconflow/Qwen/Qwen3.5-122B-A10B",
    "zhipu/glm-4-flash-250414",
    "agnes-2.0-flash",
    "sensenova-6.7-flash-lite",
    "sensenova-u1-fast"
  ],
  "subagents": {
    "agentOverrides": {
      "worker": {
        "model": "deepseek/deepseek-v4-flash"
      },
      "reviewer": {
        "model": "siliconflow/Qwen/Qwen3-Coder-30B-A3B-Instruct"
      },
      "oracle": {
        "model": "deepseek/deepseek-v4-flash"
      },
      "researcher": {
        "model": "zhipu/glm-4-flash-250414"
      },
      "context-builder": {
        "model": "siliconflow/Qwen/Qwen3.6-35B-A3B"
      },
      "planner": {
        "model": "deepseek/deepseek-v4-flash"
      },
      "scout": {
        "model": "siliconflow/Qwen/Qwen3.5-35B-A3B"
      },
      "delegate": {
        "model": "agnes-2.0-flash"
      }
    },
    "fallback": "deepseek/deepseek-v4-flash"
  },
  "defaultThinkingLevel": "high",
  "pi-fork": {
    "costFooter": true,
    "defaultModel": "siliconflow/stepfun-ai/Step-3.5-Flash",
    "defaultThinking": "minimal"
  },
  "showHardwareCursor": true,
  "packages": [
    "npm:pi-context",
    "npm:pi-ask-user",
    {
      "source": "npm:@ineersa/my-pi-extensions",
      "extensions": [
        "+extensions/focus-cursor.ts",
        "-extensions/custom-footer.ts",
        "-extensions/semantic-search/semantic-search.ts",
        "-extensions/fork/fork.ts",
        "+extensions/prompt-channels/prompt-channels.ts",
        "-extensions/safe-guard/safe-guard.ts",
        "-extensions/skill-palette/skill-palette.ts",
        "-extensions/bg-process.ts",
        "-extensions/rewind/rewind.ts",
        "-extensions/ide/ide.ts",
        "-extensions/session-status.ts",
        "-extensions/output-cap/output-cap.ts"
      ]
    },
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-btw",
    "npm:pi-web-access",
    "npm:pi-observational-memory",
    "npm:@tomxprime/planning-with-files",
    "../../projects/pi-llm-wiki",
    "npm:pi-webdav-sync",
    "npm:pi-load-skill",
    "npm:pi-model-router",
    "npm:pi-powerline-footer",
    "git:github.com/x-cmd/x-cmd",
    "npm:@jackwener/opencli",
    "git:github.com/jackwener/OpenCLI",
    "../../projects/pi-artisan",
    "npm:@axnic/pi-extension-settings",
    {
      "source": "git:github.com/DietrichGebert/ponytail",
      "extensions": [
        "pi-extension/index.js"
      ]
    },
    "git:gitee.com/wtown/pi-capabilities.git"
  ],
  "extensions": [
    "-extensions/cli-anything/index.ts"
  ],
  "skills": [
    "-skills/pi-core/context-management/SKILL.md"
  ],
  "extensions:settings": {
    "pi-extension-settings": {
      "behavior.start-in-search-mode": true,
      "behavior.max-visible-rows": 20
    }
  },
  "theme": "dark"
}
